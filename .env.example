# Email Validator Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# REQUIRED
# ==========================================

# API Key for authentication (REQUIRED for production)
API_KEY=your-secure-api-key-here

# ==========================================
# SOCKS5 PROXY (SURFSHARK VPN) - RECOMMENDED!
# ==========================================

# Get credentials from: https://my.surfshark.com/
# → VPN → Manual Setup → SOCKS5 Proxy
# This routes SMTP through clean IPs to avoid blacklists!

SOCKS5_HOST=proxy-nl.surfshark.com
SOCKS5_PORT=1080
SOCKS5_USER=your-surfshark-username
SOCKS5_PASS=your-surfshark-password

# Available Surfshark locations (choose one with good reputation):
# Netherlands: proxy-nl.surfshark.com (recommended)
# United States: proxy-us.surfshark.com  
# United Kingdom: proxy-uk.surfshark.com
# Germany: proxy-de.surfshark.com
# See full list: https://support.surfshark.com/

# ⚠️ Without SOCKS5 proxy: SMTP may fail due to IP blacklists (free hosting)
# ✅ With SOCKS5 proxy: Clean residential IPs = ZeroBounce-level accuracy!

# ==========================================
# OPTIONAL
# ==========================================

# Server Configuration
PORT=8787
NODE_ENV=development

# Optional: Custom DNS servers (comma-separated)
# DNS_SERVERS=8.8.8.8,8.8.4.4

# Optional: Rate limiting
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# Optional: CORS settings
# CORS_ORIGIN=*
